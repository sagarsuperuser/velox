# Public origin of the Velox API (no trailing slash).
# Shown in Settings → Environment as the "API Endpoint" and "Stripe Webhook URL".
# Also used as the base for fetches from customer-portal pages.
# Leave unset in production if the web app is served from the same origin as the API.
#
# Dev:  http://localhost:8080
# Prod: https://api.velox.dev
VITE_API_URL=http://localhost:8080
