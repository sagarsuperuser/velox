{
  "uid": "velox-coupons",
  "title": "Velox — Coupons",
  "description": "Redeem latency, outcome breakdown, and volume for the /v1/coupons/redeem hot path.",
  "tags": ["velox", "coupons", "billing"],
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "Prometheus" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Redeem latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(velox_http_request_duration_seconds_bucket{path=\"/v1/coupons/redeem\"}[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(velox_http_request_duration_seconds_bucket{path=\"/v1/coupons/redeem\"}[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(velox_http_request_duration_seconds_bucket{path=\"/v1/coupons/redeem\"}[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "id": 2,
      "title": "Redeem throughput (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        {
          "expr": "sum(rate(velox_http_requests_total{path=\"/v1/coupons/redeem\"}[5m]))",
          "legendFormat": "all",
          "refId": "A"
        },
        {
          "expr": "sum(rate(velox_http_requests_total{path=\"/v1/coupons/redeem\",status=~\"2..\"}[5m]))",
          "legendFormat": "2xx",
          "refId": "B"
        }
      ]
    },
    {
      "id": 3,
      "title": "Redeem outcomes (stacked)",
      "description": "Each series is a domain outcome code. 'success' / 'replay' are the healthy paths. Business-rule rejections (coupon_expired, coupon_min_amount_not_met, …) and 'invalid_request' (bad caller input) are expected and not alerted on. 'error' is the infra / unknown bucket — rises here are a page.",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "bars",
            "stacking": { "mode": "normal", "group": "A" },
            "fillOpacity": 80
          }
        }
      },
      "targets": [
        {
          "expr": "sum by (outcome) (rate(velox_coupon_redemptions_total[5m]))",
          "legendFormat": "{{outcome}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Infra error rate (5xx + untyped)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 16, "w": 6, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.02 },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      },
      "options": { "colorMode": "background", "graphMode": "area" },
      "targets": [
        {
          "expr": "sum(rate(velox_coupon_redemptions_total{outcome=\"error\"}[15m])) / (sum(rate(velox_coupon_redemptions_total[15m])) > 0)",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "p95 latency (now)",
      "type": "stat",
      "gridPos": { "x": 6, "y": 16, "w": 6, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.25 },
              { "color": "red", "value": 0.5 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(velox_http_request_duration_seconds_bucket{path=\"/v1/coupons/redeem\"}[10m])) by (le))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Redemptions in last 24h",
      "type": "stat",
      "gridPos": { "x": 12, "y": 16, "w": 6, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        {
          "expr": "sum(increase(velox_coupon_redemptions_total{outcome=\"success\"}[24h]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Replay rate (idempotency retries)",
      "type": "stat",
      "gridPos": { "x": 18, "y": 16, "w": 6, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Share of redeems served from the idempotency cache. A sustained high replay rate is fine (clients retrying correctly); a sudden climb can mean a downstream consumer is double-posting.",
      "fieldConfig": { "defaults": { "unit": "percentunit" } },
      "targets": [
        {
          "expr": "sum(rate(velox_coupon_redemptions_total{outcome=\"replay\"}[15m])) / (sum(rate(velox_coupon_redemptions_total[15m])) > 0)",
          "refId": "A"
        }
      ]
    }
  ]
}
