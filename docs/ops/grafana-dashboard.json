        }
      ],
      "description": "Scrape-time gauges (RegisterQueueDepthGauges, shipped 2026-07-06): pending email/webhook outbox rows. A value of -1 means the count query itself failed. The runbook alerts at > 1000."
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 67 },
