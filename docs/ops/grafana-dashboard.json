      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 50 },
      "id": 13,
      "targets": [
        {
          "expr": "velox_dunning_active_runs",
          "legendFormat": "active",
          "refId": "A"
        }
      ],
      "description": "Scrape-time gauge (RegisterQueueDepthGauges, shipped 2026-07-06): counts invoice_dunning_runs WHERE state='active'. A value of -1 means the count query itself failed."
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 58 },
      "id": 500,
      "title": "Outboxes",
