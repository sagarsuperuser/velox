# Velox local development environment
# Copy to .env and fill in your values:  cp .env.example .env

# Database — admin/migration role URL (table owner; used for migrations and
# the handful of privileged boot queries).
DATABASE_URL=postgres://velox:velox@localhost:5432/velox?sslmode=disable

# Runtime database URL — the least-privilege velox_app role RLS is enforced
# under. REQUIRED when APP_ENV is staging/production (boot refuses the default
# velox_app password there). Local dev may leave it unset: the app derives
# velox_app:velox_app from DATABASE_URL (role created by docker/init.sql on
# first `docker compose up`, or deploy/compose's init script).
APP_DATABASE_URL=

# Server
PORT=8080
APP_ENV=local
RUN_MIGRATIONS_ON_BOOT=true

# Log verbosity. Standard slog levels: debug | info | warn | error.
# Unset or unrecognized → info. Use debug to surface scheduler tick
# heartbeats (email outbox, webhook outbox, billing) and other
# verbose-by-default-suppressed diagnostics. Bump back to info before
# committing — debug is noisy in production log volume.
LOG_LEVEL=info

# Bootstrap — required to use POST /v1/bootstrap endpoint
# Generate with: openssl rand -hex 32
VELOX_BOOTSTRAP_TOKEN=

# Bootstrap owner — read by `make bootstrap` (cmd/velox-bootstrap), not the
# server. Bootstrap ALWAYS creates a dashboard owner login: email defaults to
# admin@velox.local; password (min 12 chars) defaults to a generated one,
# printed once in the bootstrap output. VELOX_BOOTSTRAP_TENANT names the
# tenant (default "Demo Tenant").
VELOX_BOOTSTRAP_EMAIL=
VELOX_BOOTSTRAP_PASSWORD=
VELOX_BOOTSTRAP_TENANT=

# Encryption — 64 hex chars (32 bytes). REQUIRED in production.
# Used to encrypt customer PII and per-tenant Stripe secrets at rest.
# Generate with: openssl rand -hex 32
VELOX_ENCRYPTION_KEY=

# ──────────────────────────────────────────────────────────────────────────────
# Dashboard + session
# ──────────────────────────────────────────────────────────────────────────────

# Session cookie domain. Empty = host-only (correct for localhost). In
# staging/prod, set to the registrable domain (e.g. ".velox.dev") so API
# subdomains can read the cookie issued by the dashboard origin.
VELOX_COOKIE_DOMAIN=

# Redis — used for per-tenant rate limiting. `make up` starts Redis on 6379.
# Unset → rate limiting fails open (acceptable locally; blocked in prod via
# APP_ENV=production which forces fail-closed).
REDIS_URL=redis://localhost:6379

# Stripe credentials live per-tenant in the DB (stripe_provider_credentials).
# Each tenant connects their own Stripe account via the Settings → Payments UI.

# Local dev: create a tenant, then in the UI paste the sk_test_ / pk_test_
# values from https://dashboard.stripe.com/test/apikeys. For webhook testing:
#   stripe listen --forward-to localhost:8080/v1/webhooks/stripe/<endpoint_id>
# where <endpoint_id> is the vlx_spc_... returned by the connect call; paste
# the whsec_... the CLI prints into the same settings page as the webhook
# signing secret.

# ──────────────────────────────────────────────────────────────────────────────
# Customer-facing URLs — embedded in outgoing emails
# ──────────────────────────────────────────────────────────────────────────────

# Base URL for the self-service payment-update page. Tokens are appended as a
# path segment: <URL>/<raw_token>. Unset → dunning payment-failed emails omit
# the self-service link and customers can only recover via operator action.
PAYMENT_UPDATE_URL=http://localhost:5173/update-payment

# Where the self-service payment-update flow lands after Stripe Checkout
# completes — the public "payment method added" confirmation page. Must be a
# route the SPA actually serves; the handler appends ?status=success|cancel.
PAYMENT_UPDATE_RETURN_URL=http://localhost:5173/payment-method-added

# Base URL for the customer portal. Magic-link tokens are appended as
# /portal/magic?token=<...>. Unset → server boot logs `CUSTOMER_PORTAL_URL
# NOT SET`; magic-link requests fail at send time with ErrPortalURLNotConfigured.
CUSTOMER_PORTAL_URL=http://localhost:5173

# Base URL for the hosted invoice page. Powers the "View & pay invoice" /
# "View receipt" CTAs in invoice / receipt / dunning / payment-failed emails;
# resolves to <base>/invoice/<public_token>. Unset → boot warns and emails
# render with NO link in the CTA (the email looks broken to the customer).
HOSTED_INVOICE_BASE_URL=http://localhost:5173

# Base URL for the operator dashboard SPA. Powers the password-reset email
# link (<base>/reset-password?token=<...>). Required in split-origin dev
# (Vite :5173 vs API :8080) — without it the link points at the API
# server which doesn't serve /reset-password and the operator hits a 404.
# In single-origin prod (api + dashboard same domain) it can stay unset
# and the request Host is used.
DASHBOARD_BASE_URL=http://localhost:5173

# ──────────────────────────────────────────────────────────────────────────────
# Email — SMTP sender config. If SMTP_HOST is empty, every send returns
# ErrSMTPNotConfigured and the dispatcher retries until DLQ — there is no
# stdout fallback (see internal/email/sender.go). Outbound rows always land
# in the email_outbox table first — inspect with:
#   SELECT email_type, payload, status FROM email_outbox ORDER BY created_at DESC;
# ──────────────────────────────────────────────────────────────────────────────

# SMTP_TLS controls the transport-security mode (see internal/email/sender.go):
#   starttls — STARTTLS upgrade after plain connect (port 587). Industry default
#              for SMTP submission; what Gmail/SendGrid/Postmark/Zoho/Mailtrap use.
#   implicit — TLS from the first byte via tls.Dial (port 465). Older but still
#              supported by most providers.
#   none     — Plain SMTP, no TLS (port 1025). Only safe for local Mailpit; never
#              use against a public relay.
# Unset defaults to `starttls` with a boot WARN.

# Option 1 — Mailpit (recommended for local dev). Starts via `make up`; web UI
# at http://localhost:8025 catches every outbound email, renders HTML + text,
# and stores attachments (e.g. invoice PDFs). Nothing leaves the machine.
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_TLS=none
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=billing@velox.local

# Option 2 — Mailtrap (sandbox SMTP for testing real STARTTLS path without
# touching production providers). Sign up at mailtrap.io, paste the credentials
# from the inbox's SMTP Settings panel. Every send lands in the Mailtrap inbox
# UI — nothing leaves their sandbox. Useful for verifying the STARTTLS code
# path (FLOW E1) without burning Zoho's daily quota or hitting a real recipient.
# SMTP_HOST=sandbox.smtp.mailtrap.io
# SMTP_PORT=587
# SMTP_TLS=starttls
# SMTP_USERNAME=<from mailtrap dashboard>
# SMTP_PASSWORD=<from mailtrap dashboard>
# SMTP_FROM=billing@velox.local

# Option 3 — Zoho Mail (real delivery; useful for proofing copy end-to-end).
# Comment out the Mailpit block above and uncomment the lines below.
# Gotchas:
#   • Use port 587 with STARTTLS (industry default for submission). Port 465
#     with SMTP_TLS=implicit also works.
#   • SMTP_PASSWORD is a Zoho *app password*, not your login password.
#     Generate at: https://accounts.zoho.com/home#security/app_passwords
#   • SMTP_FROM must match SMTP_USERNAME or a Zoho-verified alias — Zoho
#     rejects spoofed From headers.
#   • Regional hosts: smtp.zoho.in (India), smtp.zoho.eu (EU), smtp.zoho.com (US/global).
#   • Free tier caps at ~50 recipients/day. Use real addresses you own when
#     testing — Zoho actually delivers, so a typo'd address reaches a real inbox.
# SMTP_HOST=smtp.zoho.com
# SMTP_PORT=587
# SMTP_TLS=starttls
# SMTP_USERNAME=you@yourdomain.com
# SMTP_PASSWORD=<16-char-app-password>
# SMTP_FROM=you@yourdomain.com

# ──────────────────────────────────────────────────────────────────────────────
# Operational — sensible defaults, tweak per environment
# ──────────────────────────────────────────────────────────────────────────────

# Bearer token required to scrape /metrics. Empty = unauthenticated access
# (acceptable in local dev only). Set a long random token in staging/prod.
METRICS_TOKEN=

# Comma-separated list of proxy IPs/CIDRs whose X-Forwarded-For / X-Real-IP
# headers are trusted for client-IP resolution (rate limiting, audit logs).
# Empty = headers ignored; the direct TCP peer is the client IP. Set to your
# load balancer / reverse proxy CIDR when Velox runs behind one.
TRUST_PROXY=

# Public base URL of THIS API, used to compose the shareable cost-dashboard
# URL returned by the token-rotate endpoint. Unset = derived from the request.
VELOX_API_BASE_URL=

# Comma-separated list of origins allowed to call the API. Default covers
# the Vite dev server ports. Include your deployed dashboard origin in prod.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174

# Blind-index key for encrypted email columns (64 hex chars, independent of
# VELOX_ENCRYPTION_KEY). When set, enables indexed equality search on
# customer email without decrypting every row. Unset → email search falls
# back to full-scan decryption (fine for <10k customers). Generate with:
#   openssl rand -hex 32
VELOX_EMAIL_BIDX_KEY=

