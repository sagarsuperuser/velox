# Velox local development environment
# Copy to .env and fill in your values:  cp .env.example .env

# Database — superuser for migrations, app user for runtime
DATABASE_URL=postgres://velox:velox@localhost:5432/velox?sslmode=disable
APP_DATABASE_URL=postgres://velox_app:velox_app@localhost:5432/velox?sslmode=disable

# Server
PORT=8080
APP_ENV=local
RUN_MIGRATIONS_ON_BOOT=true

# Bootstrap — required to use POST /v1/bootstrap endpoint
# Generate with: openssl rand -hex 32
VELOX_BOOTSTRAP_TOKEN=

# Stripe (optional — payment features disabled without these)
# Get test keys from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
