# Velox local development environment
# Copy to .env and fill in your values:  cp .env.example .env

# Database — superuser URL for migrations. At runtime the app swaps the
# credentials to velox_app:velox_app for RLS-enforced queries (role must exist).
DATABASE_URL=postgres://velox:velox@localhost:5432/velox?sslmode=disable

# Server
PORT=8080
APP_ENV=local
RUN_MIGRATIONS_ON_BOOT=true

# Bootstrap — required to use POST /v1/bootstrap endpoint
# Generate with: openssl rand -hex 32
VELOX_BOOTSTRAP_TOKEN=

# Encryption — 64 hex chars (32 bytes). REQUIRED in production.
# Used to encrypt customer PII and per-tenant Stripe secrets at rest.
# Generate with: openssl rand -hex 32
VELOX_ENCRYPTION_KEY=

# Stripe credentials live per-tenant in the DB (stripe_provider_credentials).
# Each tenant connects their own Stripe account via the Settings → Payments UI.
# There are no platform-level STRIPE_* env vars — the operator does not hold
# any tenant's Stripe secrets.
#
# Local dev: create a tenant, then in the UI paste the sk_test_ / pk_test_
# values from https://dashboard.stripe.com/test/apikeys. For webhook testing:
#   stripe listen --forward-to localhost:8080/v1/webhooks/stripe/<endpoint_id>
# where <endpoint_id> is the vlx_spc_... returned by the connect call; paste
# the whsec_... the CLI prints into the same settings page as the webhook
# signing secret.
