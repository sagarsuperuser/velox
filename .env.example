# Database
DATABASE_URL=postgres://velox:velox@localhost:5432/velox?sslmode=disable

# Or use discrete vars:
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=velox
# DB_USER=velox
# DB_PASSWORD=velox
# DB_SSLMODE=disable

# Server
PORT=8080
APP_ENV=local

# Auto-run migrations on boot
RUN_MIGRATIONS_ON_BOOT=true
